# Cluster / infra
# The supplied SolInfra endpoint is mainnet-beta. Keep the real key in .env only.
SOLANA_RPC_URL=https://fra.rpc.solinfra.dev/sol?api_key=YOUR_SOLINFRA_KEY
YELLOWSTONE_ENDPOINT=fra.grpc.solinfra.dev:443
YELLOWSTONE_X_TOKEN=YOUR_SOLINFRA_KEY
NETWORK=mainnet-beta

# Jito block engine. Use a mainnet endpoint for bounty-valid bundle submissions.
JITO_BLOCK_ENGINE_HTTP=https://frankfurt.mainnet.block-engine.jito.wtf
JITO_BLOCK_ENGINE_GRPC=frankfurt.mainnet.block-engine.jito.wtf
JITO_TIP_FLOOR_URL=https://bundles.jito.wtf/api/v1/bundles/tip_floor

# Wallet. This must be funded with small SOL for real mainnet bundle tests.
# Base58 secret key, JSON byte array, or absolute path to a keypair file.
PAYER_PRIVATE_KEY=your-base58-secret-key

# AI retry agent
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.5

# Safety rails
DB_PATH=data/lifecycle/txstack.sqlite
MIN_TIP_LAMPORTS=1000
MAX_TIP_LAMPORTS=200000
DEFAULT_BUNDLE_COUNT=10
LEADER_WINDOW_SLOTS=2
SUBMISSION_POLL_MS=500
DASHBOARD_PORT=8787
